# OpenSubtitles API v2 key (https://www.opensubtitles.com/consumers)
OPENSUBTITLES_API_KEY=your_api_key_here

# HuggingFace API token for critic review analysis (https://huggingface.co/settings/tokens)
HF_TOKEN=your_hf_token_here

# GitHub token for submitting shared critic scores (fine-grained, issues:write on watchflix-scores)
GITHUB_TOKEN=your_github_token_here

# Optional overrides
# PORT=3001
# OMDB_API_KEY=your_omdb_key
